# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Auth
VITE_GOOGLE_CLIENT_ID=

# Cloudflare Turnstile (CAPTCHA on sign-up / sign-in / password reset forms).
# Without this, the widget cannot load. From Cloudflare dashboard → Turnstile.
VITE_TURNSTILE_SITE_KEY=

# Firebase Auth (Phase 0 of Firebase migration — see .claude/plans/lets-now-plan-for-melodic-bee.md)
# From Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# App
VITE_APP_ENV=development

# SEO / crawlers — controls the generated robots.txt at build time (web/vite.config.ts).
# Set to "true" ONLY on the production Vercel deploy (devcon.plus) so it emits
# "Allow: /". Leave unset/empty on staging (staging.devcon.plus) so it emits
# "Disallow: /" and stays out of search engines. Default (unset) = blocked.
VITE_ALLOW_INDEXING=

# Backend API
VITE_API_URL=http://localhost:8000
