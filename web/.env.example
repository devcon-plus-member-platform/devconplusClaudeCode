# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Auth
VITE_GOOGLE_CLIENT_ID=

# Firebase Auth (Phase 0 of Firebase migration — see .claude/plans/lets-now-plan-for-melodic-bee.md)
# From Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Auth provider feature flag
# 'supabase' = legacy direct Supabase Auth (default, current behavior, we will remove this Pre-Launch)
# 'firebase' = new path via NestJS bridge (enabled in Phase 0 of Firebase migration)
VITE_AUTH_PROVIDER=firebase

# App
VITE_APP_ENV=development

# Backend API
VITE_API_URL=http://localhost:8000
