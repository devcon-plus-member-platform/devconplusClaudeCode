# App
PORT=8000
NODE_ENV=production

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Firebase Web API key — used by /auth/email/signin (REST sign-in to verify passwords).
# Firebase Console → Project Settings → General → Web API key.
FIREBASE_WEB_API_KEY=

# Firebase Admin SDK
# Minify the downloaded Firebase service-account JSON to a single line and wrap it in single quotes:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...",...}'
FIREBASE_SERVICE_ACCOUNT_JSON=

# Email (Gmail SMTP)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Secret for signing email verification JWTs (stateless, 24h TTL).
EMAIL_VERIFICATION_SECRET=

# Public frontend base URL — used for post-verification redirects in emails.
# Staging: https://staging.cloud-engineer.dev | Production: https://plus.devcon.ph
APP_URL=https://staging.cloud-engineer.dev

# Public backend base URL — used for verification links that hit NestJS first.
# Staging: https://api.cloud-engineer.dev | Production (future): https://api.devcon.ph
SERVER_URL=https://api.cloud-engineer.dev

# QR pipeline — must match the Supabase Edge Function secret exactly.
QR_JWT_SECRET=

# Cloudflare Turnstile secret key — verifies the sign-up CAPTCHA token server-side.
# Pairs with the frontend VITE_TURNSTILE_SITE_KEY. From Cloudflare dashboard → Turnstile.
# If blank, server-side captcha verification is skipped (fail-open).
TURNSTILE_SECRET_KEY=

# Frontend origins for CORS (no trailing slash). Comma-separate multiple values.
# Include the Vercel deployment URL until the custom domain is fully live.
# localhost:5173 lets local dev hit the staging API — drop it at prod hardening.
CORS_ORIGIN=https://staging.cloud-engineer.dev,https://devconplus-dev-nine.vercel.app,https://plus.devcon.ph,http://localhost:5173

# Cache (Upstash Redis) — OPTIONAL. Absent => no-op mode (no caching, app unaffected).
# Same DB can back local/staging/prod; CACHE_PREFIX keeps their keys isolated.
# IMPORTANT: set CACHE_PREFIX explicitly — NODE_ENV is "production" on BOTH the
# staging and prod slots, so the prefix is the only thing that separates them.
#   staging slot -> CACHE_PREFIX=staging   |   prod slot -> CACHE_PREFIX=prod
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_PREFIX=prod
