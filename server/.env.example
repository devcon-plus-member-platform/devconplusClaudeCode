# App
PORT=8000
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Firebase Web API key — used by /auth/email/signin (REST sign-in to verify passwords).
# Firebase Console → Project Settings → General → Web API key.
FIREBASE_WEB_API_KEY=

# Firebase Admin SDK (Phase 0 of Firebase Auth migration)
# Download: Firebase Console → Project Settings → Service Accounts → Generate New Private Key.
# Minify to single-line and copy to clipboard:
#   PowerShell:  Get-Content -Raw .\firebase-adminsdk.json | ConvertFrom-Json | ConvertTo-Json -Compress | Set-Clipboard
#   Node:        node -e "console.log(JSON.stringify(require('./firebase-adminsdk.json')))" | clip
# Wrap the pasted value in SINGLE quotes (the JSON itself contains double quotes).
# Example: FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...",...}'
# Then DELETE the downloaded .json file — it's a master credential for your Firebase project.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Email (Gmail SMTP)
# Use a dedicated Gmail / Google Workspace account for sending.
# Create an App Password at: Google Account → Security → 2-Step Verification → App Passwords
# This is a 16-char code — NOT your account password.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Secret for signing email verification JWTs (stateless, 24h TTL).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_VERIFICATION_SECRET=

# Public frontend base URL — used for post-verification redirect targets in emails.
APP_URL=http://localhost:5173

# Public server (NestJS) base URL — used to build verification links that must
# hit the backend first (/auth/email/verify) before redirecting to the frontend.
# Local: http://localhost:8000  |  Production: https://your-cloud-run-url.run.app
SERVER_URL=http://localhost:8000

# QR pipeline — HMAC-SHA256 secret for signing/verifying short-lived QR JWTs.
# Must match the QR_JWT_SECRET Supabase Edge Function secret exactly.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then deploy: supabase secrets set QR_JWT_SECRET=<value>
QR_JWT_SECRET=

# Cloudflare Turnstile secret key — verifies the sign-up CAPTCHA token server-side.
# Pairs with the frontend VITE_TURNSTILE_SITE_KEY. From Cloudflare dashboard → Turnstile.
# OPTIONAL: if blank, server-side captcha verification is skipped (fail-open).
TURNSTILE_SECRET_KEY=

# Frontend origin for CORS (no trailing slash). Comma-separate multiple.
CORS_ORIGIN=http://localhost:5173

# Cache (Upstash Redis) — OPTIONAL. Leave blank to run the backend with no cache
# (no-op mode; identical behavior to pre-cache). To enable: create a Redis DB in
# the Upstash console (pick the ap-southeast-1 region to match EC2) and paste the
# REST URL + token from the database's "REST API" section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Key namespace so the staging + prod containers can share one Upstash DB.
# Set to "staging" on the staging slot and "prod" on the prod slot. Defaults to NODE_ENV.
CACHE_PREFIX=
